@model List<Libraro.Models.Urun>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Sepetim</h2>
        @if (Model.Any())
        {
            <a href="/Sepet/Temizle" class="btn btn-outline-danger btn-sm">Sepeti Temizle</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center p-5 shadow-sm">
            <p>Sepetiniz şu an boş.</p>
            <a href="/" class="btn btn-danger rounded-pill">Alışverişe Devam Et</a>
        </div>
    }
    else
    {
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Ürün</th>
                    <th class="text-center">Adet</th>
                    <th class="text-end">Fiyat</th>
                    <th class="text-end">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grup in Model.GroupBy(x => x.Id))
                {
                    var urun = grup.First();
                    var adet = grup.Count();
                    <tr>
                        <td>
                            <img src="@urun.ResimYolu" style="width:40px; margin-right:10px;">
                            @urun.Ad
                        </td>
                        <td class="text-center">
                            <div class="btn-group btn-group-sm">
                                <a href="/Sepet/Cikar/@urun.Id" class="btn btn-light border">-</a>
                                <span class="btn btn-light border disabled">@adet</span>
                                <a href="/Sepet/Arttir/@urun.Id" class="btn btn-light border">+</a>
                            </div>
                        </td>
                        <td class="text-end">@((urun.Fiyat * adet).ToString("C2"))</td>
                        <td class="text-end">
                            <a href="/Sepet/Cikar/@urun.Id" class="text-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="text-end mt-4">
            <h4>Toplam: <span class="text-danger">@Model.Sum(x => x.Fiyat).ToString("C2")</span></h4>
            <button class="btn btn-danger btn-lg mt-3 px-5 rounded-pill">Ödemeye Geç</button>
        </div>
    }
</div>