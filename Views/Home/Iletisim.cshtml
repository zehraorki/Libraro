@model Libraro.Models.IletisimMesaj

<div class="card border-0 shadow-sm p-4 mt-5" style="border-radius: 15px;">
    <h3 class="mb-2 mt-4 font-weight-bold">İletişim Formu</h3>
    <h5 class="mb-5 text-muted small">Lütfen iletişim bilgilerinizi eksiksiz doldurmaya özen gösteriniz.</h5>

    <form asp-action="Iletisim" method="post">
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="small font-weight-bold">Ad</label>
                <input asp-for="Ad" type="text" class="form-control rounded-pill border-light bg-light"
                    placeholder="Adınız" required>
            </div>
            <div class="col-md-6 mb-3">
                <label class="small font-weight-bold">Soyad</label>
                <input asp-for="Soyad" type="text" class="form-control rounded-pill border-light bg-light"
                    placeholder="Soyadınız" required>
            </div>
        </div>

        <div class="mb-3">
            <label class="small font-weight-bold">E-Posta</label>
            <input asp-for="Email" type="email" class="form-control rounded-pill border-light bg-light"
                placeholder="E-posta adresiniz" required>
        </div>

        <div class="mb-3">
            <label class="small font-weight-bold">Telefon</label>
            <input asp-for="Telefon" type="tel" class="form-control rounded-pill border-light bg-light"
                placeholder="05xx xxx xx xx" required>
        </div>

        <div class="mb-3">
            <label class="small font-weight-bold">Konu</label>
            <input asp-for="Konu" type="text" class="form-control rounded-pill border-light bg-light"
                placeholder="Mesajınızın konusu" required>
        </div>

        <div class="mb-4">
            <label class="small font-weight-bold">Mesaj</label>
            <textarea name="Mesaj" class="form-control border-light bg-light" rows="4" style="border-radius: 15px;"
                placeholder="Mesajınızı buraya yazın..."></textarea>
        </div>

        <button type="submit" class="btn btn-danger btn-block rounded-pill shadow-sm py-2 w-100">
            <i class="fas fa-paper-plane mr-2"></i> Gönder
        </button>
    </form>
</div>