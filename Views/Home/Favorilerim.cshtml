@model List<Libraro.Models.Urun>

<div class="container mt-5 py-4">
    <h2 class="text-center font-weight-bold mb-5" style="color: #2c3e50;">Favori Ürünlerim</h2>

    <div class="row">
        @if (!Model.Any())
        {
            <p>Henüz favori ürününüz yok. Keşfetmeye başlayın!</p>
        }
        else
        {
            @foreach (var urun in Model)
            {
                <div class="col-6 col-md-4 col-lg-3 mb-4">
                    <div class="card h-100 shadow-sm text-center p-2" style="border-radius: 15px; border: none;">
                        <div style="height: 200px; display: flex; align-items: center; justify-content: center;">
                            <img src="@urun.ResimYolu" class="card-img-top" alt="@urun.Ad"
                        style="max-height: 180px; width: auto; object-fit: contain;">
                        </div>
                        <div class="card-body p-2">
                            <h6 class="card-title font-weight-bold text-truncate" style="font-size: 0.9rem;">@urun.Ad</h6>
                            <p class="text-danger font-weight-bold mb-2">@urun.Fiyat.ToString("C2")</p>

                            <form asp-action="FavoriGuncelle" asp-controller="Home" method="post">
                                <input type="hidden" name="id" value="@urun.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100 rounded-pill">
                                    Çıkar
                                </button>
                            </form>

                            <form asp-action="Ekle" asp-controller="Sepet" method="post" class="mt-2">
                                <input type="hidden" name="id" value="@urun.Id" />
                                <button type="submit" class="btn btn-sm btn-danger w-100 rounded-pill">
                                    Sepete Ekle
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>