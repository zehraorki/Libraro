@model Libraro.Models.Kullanici

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 border p-4 shadow-sm" style="border-radius: 15px;">
            <h2 class="text-center mb-4" style="color: #b22222;">Kayıt Ol</h2>
            <form asp-action="Register" method="post">
                <div class="mb-3">
                    <label class="form-label">Ad Soyad</label>
                    <input asp-for="AdSoyad" class="form-control" placeholder="Adınızı giriniz" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">E-posta</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="Örn: libraro@example.com" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Şifre</label>
                    <input asp-for="Sifre" type="password" class="form-control" placeholder="******" required>
                </div>
                <button type="submit" class="btn w-100 text-white" style="background-color: #b22222;">Kayıt Ol</button>
            </form>
        </div>
    </div>
</div>